<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="postQuantumContainer" managed="false" visible="false" spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cryptoforge.ui.PostQuantumController">
    <Accordion fx:id="pqcAccordion">
        <panes>
            <TitledPane text="🔑 PQC Key Generation" expanded="true">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="Algorithm (NIST Standards):"/>
                    <ComboBox fx:id="pqcAlgorithmCombo" prefWidth="300" style="-fx-font-size: 11px;"/>
                    <Button text="Generate Key Pair" onAction="#handleGeneratePQCKeyPair" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                    <HBox spacing="8">
                        <Button text="Import PEM Keys..." onAction="#handleImportPQCKeys" styleClass="secondary-button" style="-fx-font-size: 11px;"/>
                        <Button text="Export Public..." onAction="#handleExportPQCPublicKey" styleClass="secondary-button" style="-fx-font-size: 11px;"/>
                        <Button text="Export Private..." onAction="#handleExportPQCPrivateKey" styleClass="secondary-button" style="-fx-font-size: 11px;"/>
                    </HBox>
                    <Label fx:id="pqcKeyStatusLabel" text="Ready" style="-fx-font-size: 10px;"/>
                    <TabPane tabClosingPolicy="UNAVAILABLE" prefHeight="300">
                        <Tab text="Public Key">
                            <TextArea fx:id="pqcPublicKeyArea" wrapText="true" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                        </Tab>
                        <Tab text="Private Key">
                            <TextArea fx:id="pqcPrivateKeyArea" wrapText="true" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                        </Tab>
                        <Tab text="Key Details">
                            <TextArea fx:id="pqcKeyDetailsArea" wrapText="true" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                        </Tab>
                    </TabPane>
                </VBox>
            </TitledPane>
            <TitledPane text="🔏 PQC Sign / Verify">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="Algorithm:"/>
                    <ComboBox fx:id="pqcSignAlgoCombo" prefWidth="300" style="-fx-font-size: 11px;"/>

                    <Label text="Data to Sign (UTF-8):"/>
                    <TextArea fx:id="pqcSignInputArea" prefHeight="80" style="-fx-font-family: 'Monospaced';"/>

                    <Button text="Sign Data" onAction="#handlePQCSign" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                    <Label text="Signature (Hex):"/>
                    <TextArea fx:id="pqcSignOutputArea" prefHeight="80" editable="false" style="-fx-font-family: 'Monospaced';"/>

                    <Separator/>

                    <Label text="Verify Signature (Paste Hex):"/>
                    <TextField fx:id="pqcVerifySignatureField" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                    <Button text="Verify Signature" onAction="#handlePQCVerify" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                </VBox>
            </TitledPane>
            <TitledPane text="🎓 KEM Educational Demo (Alice &amp; Bob)">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="This demo illustrates the Key Encapsulation Mechanism (KEM). It is not a full communication protocol." wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>

                    <Label text="1. Alice generates a key pair (uses the ML-KEM key generated above)." style="-fx-font-weight: bold;"/>
                    <Label text="KEM algorithm:"/>
                    <ComboBox fx:id="pqcKemAlgoCombo" prefWidth="300" style="-fx-font-size: 11px;"/>

                    <Label text="2. Bob uses Alice's public key to encapsulate a shared secret." style="-fx-font-weight: bold;"/>
                    <Button text="Bob: Encapsulate Shared Secret" onAction="#handlePQCEncapsulate" styleClass="action-button" maxWidth="240" style="-fx-font-size: 11px;"/>
                    <Label text="Encapsulation Ciphertext sent to Alice (Hex):"/>
                    <TextArea fx:id="pqcKemCiphertextArea" prefHeight="50" editable="false" wrapText="true" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                    <Label text="Bob's Shared Secret (Hex):"/>
                    <TextField fx:id="pqcKemSharedSecretField" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>

                    <Separator/>

                    <Label text="3. Alice decapsulates the ciphertext using her private key." style="-fx-font-weight: bold;"/>
                    <Button text="Alice: Decapsulate Ciphertext" onAction="#handlePQCDecapsulate" styleClass="secondary-button" maxWidth="240" style="-fx-font-size: 11px;"/>
                    <Label text="Alice's Shared Secret (Hex):"/>
                    <TextField fx:id="pqcAliceSecretField" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>

                    <Label fx:id="pqcKemStatusLabel" text="Generate an ML-KEM key pair to begin." style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                </VBox>
            </TitledPane>

            <TitledPane text="⏱️ Benchmark &amp; Performance">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="Algorithm:"/>
                    <ComboBox fx:id="pqcBenchmarkAlgoCombo" prefWidth="300" style="-fx-font-size: 11px;"/>
                    <HBox spacing="10">
                        <Button fx:id="pqcBenchmarkBtn" text="Run Benchmark" onAction="#handlePQCBenchmark" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                        <ProgressIndicator fx:id="pqcBenchmarkProgress" visible="false" prefWidth="20" prefHeight="20"/>
                    </HBox>
                    <TextArea fx:id="pqcBenchmarkArea" prefHeight="150" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                </VBox>
            </TitledPane>
        </panes>
    </Accordion>
</VBox>
