                                                </Tab>
                                                <Tab text="Private Key">
                                                    <TextArea fx:id="ecdsaPrivateKeyArea" wrapText="true" editable="false"
                                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                              promptText="Private key will appear here..."/>
                                                </Tab>
                                            </TabPane>
                                        </VBox>
                                    </TitledPane>

