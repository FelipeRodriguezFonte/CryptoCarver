<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>
<?import com.cryptocarver.ui.NavigationRail?>
<?import com.cryptocarver.ui.SidePanel?>

<BorderPane fx:id="mainPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cryptocarver.ui.ModernMainController">

    <!-- Menu Bar -->
    <top>
        <VBox>
            <MenuBar fx:id="mainMenuBar" styleClass="main-menu-bar">
                <Menu text="File">
                    <MenuItem text="Import Key..." onAction="#handleImportKey" accelerator="Ctrl+O" />
                    <SeparatorMenuItem />
                    <MenuItem text="Save Session" onAction="#handleSaveSession" accelerator="Ctrl+S" />
                    <MenuItem text="Export History..." onAction="#handleExportHistory" />
                    <SeparatorMenuItem />
                    <MenuItem text="Exit" onAction="#handleExit" accelerator="Ctrl+Q" />
                </Menu>

                <Menu text="Edit">
                    <MenuItem text="Clear Input" onAction="#handleClearInput" accelerator="Ctrl+Shift+I" />
                    <MenuItem text="Clear Output" onAction="#handleClearOutput" accelerator="Ctrl+Shift+O" />
                    <MenuItem text="Copy Output" onAction="#handleCopyOutput" accelerator="Ctrl+C" />
                    <MenuItem text="Add Output to Clipboard Shelf" onAction="#handleAddCurrentOutputToShelf" />
                </Menu>

                <Menu text="View">
                    <MenuItem text="Toggle Side Panel" onAction="#handleToggleSidePanel" accelerator="Ctrl+B" />
                    <MenuItem text="Toggle Inspector" onAction="#handleToggleInspector" accelerator="Ctrl+I" />
                    <MenuItem text="Expand Result" onAction="#handleOpenExpandedResultViewer" accelerator="Ctrl+Shift+E" />
                    <MenuItem text="Expand Table" onAction="#handleOpenExpandedTableViewer" accelerator="Ctrl+Shift+T" />
                    <SeparatorMenuItem/>
                    <MenuItem text="Zoom In (Font)" onAction="#handleIncreaseFontSize" accelerator="Ctrl+PLUS" />
                    <MenuItem text="Zoom Out (Font)" onAction="#handleDecreaseFontSize" accelerator="Ctrl+MINUS" />
                    <SeparatorMenuItem/>
                    <MenuItem text="Reset to Defaults" onAction="#handleResetView"/>
                </Menu>

                <Menu text="Tools">
                    <MenuItem text="Epoch Converter" onAction="#handleEpochConverter" accelerator="Ctrl+T"/>
                    <MenuItem text="JSON Formatter" onAction="#handleJsonFormatter" accelerator="Ctrl+J"/>
                    <MenuItem text="Byte Inspector" onAction="#handleByteInspector"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Clear Lab Key Cache" onAction="#handleClearLabKeyCache"/>
                </Menu>

                <Menu text="Help">
                    <MenuItem text="Diagnostics" onAction="#handleDiagnostics"/>
                    <MenuItem text="About" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>

            <!-- Toolbar -->
            <HBox styleClass="main-toolbar">
                <Button text="Save Session" onAction="#handleSaveSession" styleClass="link-button"/>
                <Button text="Clear" onAction="#handleClearInput" styleClass="link-button"/>

                <Label text="Input Format:"/>
                <ComboBox fx:id="inputFormatCombo" prefWidth="150"/>

                <Label text="Output Format:"/>
                <ComboBox fx:id="outputFormatCombo" prefWidth="150"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Expand Result" onAction="#handleOpenExpandedResultViewer" styleClass="link-button"/>
                <Button text="Add to Shelf" onAction="#handleAddCurrentOutputToShelf" styleClass="link-button"/>
                <Button text="Copy Output" onAction="#handleCopyOutput" styleClass="link-button"/>
            </HBox>
        </VBox>
    </top>

    <!-- Main Content Area with Rail + SidePanel + Content + Inspector -->
    <center>
        <HBox>
            <!-- Navigation Rail (left, 48px) -->
            <NavigationRail fx:id="navigationRail"/>

            <!-- Side Panel (280px, collapsible) -->
            <SidePanel fx:id="sidePanel"/>

            <!-- Main Content Area -->
            <VBox fx:id="mainContentArea" HBox.hgrow="ALWAYS" styleClass="main-content-vbox">

                <!-- Content Header -->
                <HBox styleClass="content-header">
                    <Label fx:id="contentTitleLabel" text="Symmetric Keys" styleClass="content-title-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="contentSubtitleLabel" text="Key Derivation (KDF)" styleClass="content-subtitle-label"/>
                </HBox>

                <!-- Scrollable Content -->
                <ScrollPane fx:id="mainScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll-pane">
                    <VBox fx:id="contentContainer" spacing="0" styleClass="content-container-vbox">

                        <!-- PLACEHOLDER - Real content will be loaded dynamically -->
                        <Label fx:id="contentPlaceholderLabel" text="Select an operation from the side panel"
                               styleClass="placeholder-label"/>

                        <!-- This is where Symmetric Keys Accordion will be loaded -->
                        <!-- Saved Sessions Container -->
                        <!-- JOSE CONTAINER -->                        <fx:include fx:id="jose" source="jose.fxml"/>


                        <VBox fx:id="savedSessionsContainer" managed="false" visible="false" spacing="15" style="-fx-padding: 20;">
                            <!-- Header -->
                            <VBox spacing="5">
                                <Label text="Saved Sessions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                                <Label text="Restore your previous work sessions." style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;"/>
                            </VBox>

                            <!-- Sessions List -->
                            <VBox fx:id="savedSessionsList" spacing="10"/>
                        </VBox>

                        <!-- Symmetric Keys Accordion - REAL FUNCTIONALITY -->
                        <VBox fx:id="symmetricKeysContainer" managed="true" visible="true">
                            <Accordion>
                                <panes>
                                    <!-- KEY GENERATION -->
                                    <TitledPane text="🔑 Key Generation" expanded="true">
                                    <VBox spacing="4" style="-fx-padding: 6;">
                                        <GridPane hgap="6" vgap="4">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="70" prefWidth="70"/>
                                                <ColumnConstraints minWidth="180" prefWidth="220"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>

                                            <Label text="Type:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="keyTypeCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200" style="-fx-font-size: 11px;"/>

                                            <CheckBox fx:id="forceOddParityCheck" text="Force Odd Parity (DES/3DES)"
                                                      selected="true" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-size: 10px;"/>
                                        </GridPane>

                                        <Button text="Generate Key" onAction="#handleGenerateKey"
                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>

                                        <TextArea fx:id="generatedKeyField" prefHeight="280" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                  promptText="Generated key will appear here..."/>
                                    </VBox>
                                </TitledPane>

                                <!-- KEY VALIDATION -->
                                <TitledPane text="✓ Validation &amp; KCV">
                                    <VBox spacing="4" style="-fx-padding: 6;">
                                        <TextField fx:id="keyInputField" promptText="Enter key in hexadecimal..."
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>

                                        <Button text="Validate &amp; Calculate KCVs" onAction="#handleValidateKey"
                                                styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                        <TextArea fx:id="validationResultArea" prefHeight="260" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                  promptText="Validation results will appear here..."
                                                  managed="false" visible="false"/>
                                    </VBox>
                                </TitledPane>

                                <!-- KEY MATERIAL INSPECTOR -->
                                <TitledPane text="🔎 Key Material Inspector">
                                    <VBox spacing="5" style="-fx-padding: 6;">
                                        <Label text="Paste a PEM public/private key or an X.509 certificate to inspect its fingerprint, size and security hints." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <TextArea fx:id="keyMaterialInputArea" prefHeight="110" wrapText="true" promptText="-----BEGIN PUBLIC KEY----- / -----BEGIN PRIVATE KEY----- / -----BEGIN CERTIFICATE-----"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Button text="Inspect Material" onAction="#handleInspectKeyMaterial" styleClass="action-button" maxWidth="160" style="-fx-font-size: 11px;"/>
                                        <TextArea fx:id="keyMaterialReportArea" prefHeight="210" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                    </VBox>
                                </TitledPane>


                                <!-- KEYSTORE INSPECTOR -->
                                <TitledPane text="🗄 KeyStore Inspector">
                                    <VBox spacing="5" style="-fx-padding: 6;">
                                        <Label text="Lists metadata only; it never exports private or secret keys." style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <HBox spacing="5">
                                            <ComboBox fx:id="keyStoreProfileCombo" promptText="Saved profile" HBox.hgrow="ALWAYS"/>
                                            <Button text="Load" onAction="#handleLoadKeyStoreProfile" styleClass="secondary-button"/>
                                        </HBox>
                                        <HBox spacing="6">
                                            <ComboBox fx:id="keyStoreTypeCombo" prefWidth="110"/>
                                            <PasswordField fx:id="keyStorePasswordField" promptText="Store password" HBox.hgrow="ALWAYS"/>
                                        </HBox>
                                        <CheckBox fx:id="keyStoreUnsafeExtractCheck" text="Unsafe extraction: show exportable private/secret keys in clear (laboratory only)" style="-fx-font-size: 10px; -fx-text-fill: #b54708;" wrapText="true"/>
                                        <HBox spacing="5">
                                            <TextField fx:id="keyStorePathField" promptText="PKCS#12, JKS or JCEKS file path" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                                            <Button text="Browse…" onAction="#handleChooseKeyStore" styleClass="secondary-button"/>
                                        </HBox>
                                        <HBox spacing="5">
                                            <TextField fx:id="keyStoreProfileNameField" promptText="Profile name (path/type only; no password)" HBox.hgrow="ALWAYS"/>
                                            <Button text="Save Profile" onAction="#handleSaveKeyStoreProfile" styleClass="secondary-button"/>
                                        </HBox>
                                        <Button text="Inspect KeyStore" onAction="#handleInspectKeyStore" styleClass="action-button" maxWidth="160" style="-fx-font-size: 11px;"/>
                                        <TextArea fx:id="keyStoreReportArea" prefHeight="190" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                    </VBox>
                                </TitledPane>

                                <!-- PKCS#11 TOKEN (laboratory integration) -->
                                <TitledPane text="🔐 PKCS#11 Token">
                                    <VBox spacing="5" style="-fx-padding: 6;">
                                        <Label text="Connect a real laboratory token through the JVM SunPKCS11 provider. The PIN is used only for this session and is never saved." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <HBox spacing="6">
                                            <TextField fx:id="pkcs11NameField" promptText="Token profile name" prefWidth="180"/>
                                            <TextField fx:id="pkcs11SlotField" promptText="Slot index" prefWidth="90"/>
                                            <PasswordField fx:id="pkcs11PinField" promptText="User PIN (not stored)" HBox.hgrow="ALWAYS"/>
                                        </HBox>
                                        <HBox spacing="5">
                                            <TextField fx:id="pkcs11LibraryField" promptText="Native PKCS#11 library (.dylib, .so or .dll)" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                                            <Button text="Browse…" onAction="#handleChoosePkcs11Library" styleClass="secondary-button"/>
                                        </HBox>
                                        <HBox spacing="5" alignment="CENTER_LEFT">
                                            <ComboBox fx:id="pkcs11ProfileCombo" promptText="Saved Profiles" prefWidth="200"/>
                                            <Button text="Save Profile" onAction="#handleSavePkcs11Profile" styleClass="secondary-button"/>
                                            <Button text="Delete" onAction="#handleDeletePkcs11Profile" styleClass="secondary-button"/>
                                        </HBox>
                                        <HBox spacing="6">
                                            <Button text="Connect &amp; Inspect" onAction="#handleConnectPkcs11" styleClass="action-button"/>
                                            <Button text="Disconnect" onAction="#handleDisconnectPkcs11" styleClass="secondary-button"/>
                                        </HBox>
                                        <TextArea fx:id="pkcs11ReportArea" prefHeight="190" editable="false" wrapText="true"
                                                  promptText="Token provider and public object metadata will appear here; keys are never exported."
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Separator/>
                                        <Label text="Token signature test (hex data)" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                        <Label text="Uses the selected private-key object inside the token. It does not read or export the private key." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <HBox spacing="6">
                                            <ComboBox fx:id="pkcs11SigningKeyCombo" promptText="Private key alias" HBox.hgrow="ALWAYS"/>
                                            <ComboBox fx:id="pkcs11SignatureAlgorithmCombo" prefWidth="175"/>
                                        </HBox>
                                        <TextArea fx:id="pkcs11DataArea" prefHeight="55" promptText="Data to sign (hexadecimal)" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <HBox spacing="6">
                                            <Button text="Sign Data" onAction="#handlePkcs11Sign" styleClass="action-button"/>
                                            <Button text="Verify Signature" onAction="#handlePkcs11Verify" styleClass="secondary-button"/>
                                        </HBox>
                                        <TextArea fx:id="pkcs11SignatureArea" prefHeight="55" promptText="Signature (hexadecimal)" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Separator/>
                                        <Label text="Public certificate chain" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                        <HBox spacing="6">
                                            <ComboBox fx:id="pkcs11CertificateAliasCombo" promptText="Certificate alias" HBox.hgrow="ALWAYS"/>
                                            <Button text="Show PEM Chain" onAction="#handleShowPkcs11Certificate" styleClass="secondary-button"/>
                                            <Button text="Update Chain" onAction="#handleUpdatePkcs11CertificateChain" styleClass="action-button"/>
                                        </HBox>
                                        <TextArea fx:id="pkcs11CertificateArea" prefHeight="90" editable="true" promptText="Paste PEM chain here to update, or use Show PEM Chain to view." wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Separator/>
                                        <Label text="JWT / JWS using token key" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                        <Label text="Creates a compact JWS with the same selected token private-key alias. Claims must be a JSON object." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <ComboBox fx:id="pkcs11JwtAlgorithmCombo" prefWidth="150"/>
                                        <TextArea fx:id="pkcs11JwtPayloadArea" prefHeight="65" promptText='JWT claims JSON, e.g. {&quot;sub&quot;:&quot;lab&quot;}' wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Button text="Create Signed JWT" onAction="#handleGeneratePkcs11Jwt" styleClass="action-button"/>
                                        <TextArea fx:id="pkcs11JwtOutputArea" prefHeight="75" editable="false" promptText="Compact JWS will appear here" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Separator/>
                                        <Label text="CMS / PKCS#7 SignedData" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                        <Label text="Creates CMS with the selected token private-key and its public X.509 certificate. Output is Base64." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <TextArea fx:id="pkcs11CmsDataArea" prefHeight="55" promptText="Content to sign (hexadecimal)" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <CheckBox fx:id="pkcs11CmsDetachedCheck" text="Detached CMS (do not embed content)" style="-fx-font-size: 10px;"/>
                                        <Button text="Create CMS SignedData" onAction="#handleGeneratePkcs11Cms" styleClass="action-button"/>
                                        <TextArea fx:id="pkcs11CmsOutputArea" prefHeight="75" editable="false" promptText="Base64 CMS/PKCS#7 will appear here" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                    </VBox>
                                </TitledPane>

                                <!-- KEY PAIR COMPARISON -->
                                <TitledPane text="🔗 Compare Public / Private Key">
                                    <VBox spacing="5" style="-fx-padding: 6;">
                                        <Label text="Checks the pair cryptographically with a temporary signing challenge; it does not compare PEM text." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                        <TextArea fx:id="keyComparePublicArea" prefHeight="90" wrapText="true" promptText="Public key PEM or X.509 certificate PEM"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <TextArea fx:id="keyComparePrivateArea" prefHeight="90" wrapText="true" promptText="Private key PEM"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        <Button text="Compare Pair" onAction="#handleCompareKeyPair" styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                        <TextArea fx:id="keyCompareResultArea" prefHeight="100" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                    </VBox>
                                </TitledPane>

                                <!-- KEY SHARING -->
                                <TitledPane text="🔀 Key Sharing (XOR Split/Combine)">
                                    <VBox spacing="6" style="-fx-padding: 8;">
                                        <TabPane tabClosingPolicy="UNAVAILABLE">
                                            <Tab text="Split Key">
                                                <VBox spacing="6" style="-fx-padding: 8;">
                                                    <TextArea fx:id="keyToSplitField" prefHeight="35" wrapText="true"
                                                              style="-fx-font-family: 'Courier New', monospace;"
                                                              promptText="Enter key to split..."/>

                                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                                        <Label text="Parts:"/>
                                                        <ComboBox fx:id="numComponentsCombo" prefWidth="80"/>
                                                        <Button text="Split Key" onAction="#handleSplitKey"
                                                                styleClass="action-button"/>
                                                    </HBox>
                                                </VBox>
                                            </Tab>

                                            <Tab text="Combine Components">
                                                <VBox spacing="6" style="-fx-padding: 8;">
                                                    <GridPane hgap="8" vgap="4">
                                                        <columnConstraints>
                                                            <ColumnConstraints minWidth="90" prefWidth="90"/>
                                                            <ColumnConstraints hgrow="ALWAYS"/>
                                                        </columnConstraints>

                                                        <Label text="Component 1:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component1Field" promptText="Required"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                                        <Label text="Component 2:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component2Field" promptText="Required"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                                        <Label text="Component 3:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component3Field" promptText="Optional"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                                        <Label text="Component 4:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component4Field" promptText="Optional"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                                        <Label text="Component 5:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                                        <TextField fx:id="component5Field" promptText="Optional"
                                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                                  GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                                    </GridPane>

                                                    <Button text="Combine Components" onAction="#handleCombineComponents"
                                                            styleClass="action-button" maxWidth="200"/>
                                                </VBox>
                                            </Tab>
                                        </TabPane>

                                        <TextArea fx:id="componentResultsArea" prefHeight="100" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace;"
                                                  promptText="Results will appear here..."
                                                  managed="false" visible="false"/>
                                    </VBox>
                                </TitledPane>

                                <!-- KEY DERIVATION -->
                                <TitledPane text="🔐 Key Derivation (KDF)">
                                    <VBox spacing="4" style="-fx-padding: 6;">
                                        <GridPane hgap="6" vgap="4">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="90" prefWidth="90"/>
                                                <ColumnConstraints minWidth="140" prefWidth="160"/>
                                                <ColumnConstraints minWidth="70" prefWidth="75"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>

                                            <Label text="Algorithm:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="kdfAlgorithmCombo" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                                     GridPane.columnSpan="3" prefWidth="180" style="-fx-font-size: 11px;"/>

                                            <Label text="Input Format:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="kdfInputFormatCombo" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                                     prefWidth="90" style="-fx-font-size: 11px;"/>

                                            <Label text="Iterations:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="kdfIterationsField" text="10000" GridPane.rowIndex="1" GridPane.columnIndex="3"
                                                      prefWidth="60" style="-fx-font-size: 11px;"/>

                                            <Label text="Output:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                            <HBox spacing="3" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                                <TextField fx:id="kdfOutputLengthField" text="32" prefWidth="50" style="-fx-font-size: 11px;"/>
                                                <Label text="bytes" style="-fx-font-size: 10px;"/>
                                            </HBox>
                                        </GridPane>

                                        <TextField fx:id="kdfInputField" promptText="Input key material..."
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>

                                        <HBox spacing="4">
                                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                <HBox spacing="3" alignment="CENTER_LEFT">
                                                    <Label text="Salt:" style="-fx-font-size: 10px;"/>
                                                    <ComboBox fx:id="kdfSaltFormatCombo" prefWidth="70" style="-fx-font-size: 10px;"/>
                                                </HBox>
                                                <TextField fx:id="kdfSaltField" promptText="Optional" style="-fx-font-size: 10px;"/>
                                            </VBox>

                                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                <HBox spacing="3" alignment="CENTER_LEFT">
                                                    <Label text="Info:" style="-fx-font-size: 10px;"/>
                                                    <ComboBox fx:id="kdfInfoFormatCombo" prefWidth="70" style="-fx-font-size: 10px;"/>
                                                </HBox>
                                                <TextField fx:id="kdfInfoField" promptText="HKDF only" style="-fx-font-size: 10px;"/>
                                            </VBox>
                                        </HBox>

                                        <Button text="Derive Key" onAction="#handleDeriveKey"
                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>

                                        <TextArea fx:id="kdfResultArea" prefHeight="250" editable="false" wrapText="true"
                                                  style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"
                                                  promptText="Derived key will appear here..."
                                                  managed="false" visible="false"/>
                                    </VBox>
                                </TitledPane>

                                <!-- AES KEY WRAP -->
                                <TitledPane text="🔗 AES Key Wrap (RFC 3394 / RFC 5649)">
                                    <VBox spacing="5" style="-fx-padding: 6;">
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Mode:" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="keyWrapModeCombo" prefWidth="210" style="-fx-font-size: 11px;"/>
                                            <CheckBox fx:id="keyWrapUnwrapCheck" text="Unwrap" style="-fx-font-size: 11px;"/>
                                        </HBox>
                                        <TextField fx:id="keyWrapKekField" promptText="KEK AES in hexadecimal (16, 24 or 32 bytes)"
                                                   style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                        <TextField fx:id="keyWrapDataField" promptText="Key data / wrapped data in hexadecimal"
                                                   style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
