                                            </HBox>
                                            <TextArea fx:id="crlResultArea" prefHeight="150" editable="false" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        </VBox>
                                    </TitledPane>

                                    <TitledPane text="📄 PAdES PDF Signatures">
                                        <content>
                                            <fx:include fx:id="padesContainer" source="pades.fxml"/>
                                        </content>
                                    </TitledPane>

                                    <TitledPane text="📦 ASiC-S Containers">
                                        <content>
                                            <fx:include fx:id="asicContainer" source="asic.fxml"/>
                                        </content>
                                    </TitledPane>

                                    <!-- CMS OPERATIONS -->
                                    <TitledPane text="📦 CMS Operations">
                                        <VBox spacing="10" style="-fx-padding: 15;">
                                            <Label text="PKCS#7 Cryptographic Message Syntax operations" style="-fx-font-style: italic; -fx-text-fill: gray;"/>

                                            <Label text="Input Data / Content:"/>
                                            <TextArea fx:id="cmsInputArea" promptText="Enter raw data to Sign/Encrypt, or PKCS#7 PEM to Verify/Decrypt..." prefHeight="80" style="-fx-font-family: 'Monospaced';"/>

                                            <TabPane tabClosingPolicy="UNAVAILABLE">
                                                <tabs>
                                                    <Tab text="Signature (Sign/Verify)">
                                                        <content>
                                                            <VBox spacing="10" style="-fx-padding: 10;">
                                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                                    <Label text="Signing Source: " style="-fx-font-weight: bold;"/>
                                                                    <fx:define>
                                                                        <ToggleGroup fx:id="cmsSignSourceToggleGroup"/>
                                                                    </fx:define>
                                                                    <RadioButton fx:id="cmsSignSourceLocalRadio" text="Local PEM" toggleGroup="$cmsSignSourceToggleGroup" selected="true" onAction="#handleCMSourceChanged"/>
                                                                    <RadioButton fx:id="cmsSignSourcePkcs11Radio" text="PKCS#11 Token" toggleGroup="$cmsSignSourceToggleGroup" onAction="#handleCMSourceChanged"/>
                                                                </HBox>

                                                                <GridPane fx:id="cmsSignLocalGrid" hgap="10" vgap="10">
                                                                    <Label text="Signer Certificate (PEM):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                                    <TextArea fx:id="cmsSignCertArea" promptText="-----BEGIN CERTIFICATE-----..." prefHeight="80" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS" style="-fx-font-family: 'Monospaced';"/>

                                                                    <Label text="Signer Private Key (PEM):" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                                                    <TextArea fx:id="cmsSignKeyArea" promptText="-----BEGIN PRIVATE KEY-----..." prefHeight="80" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS" style="-fx-font-family: 'Monospaced';"/>
                                                                    <columnConstraints>
                                                                        <ColumnConstraints percentWidth="50"/>
                                                                        <ColumnConstraints percentWidth="50"/>
                                                                    </columnConstraints>
                                                                </GridPane>

                                                                <HBox fx:id="cmsSignPkcs11Box" spacing="10" alignment="CENTER_LEFT" managed="false" visible="false">
                                                                    <Label text="Key Alias:" />
                                                                    <ComboBox fx:id="cmsSignKeyAliasCombo" prefWidth="250"/>
                                                                    <Button text="Load Token Keys" onAction="#handleLoadCMSKeys" />
                                                                </HBox>

                                                                <Label text="Detached Data (for verification only):"/>
                                                                <TextArea fx:id="cmsVerifyDataArea" promptText="Enter original raw data here if verifying a detached signature..." prefHeight="50" style="-fx-font-family: 'Monospaced';"/>

                                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                                     <CheckBox fx:id="cmsDetachedCheck" text="Detached Signature (Sign)"/>
                                                                     <CheckBox fx:id="cmsCadesBesCheck" text="CAdES-BES (bind signing certificate)">
                                                                         <tooltip><Tooltip text="Adds the ETSI CAdES-BES signingCertificateV2 signed attribute. This is not a timestamped or long-term profile."/></tooltip>
                                                                     </CheckBox>
                                                                     <CheckBox fx:id="cmsCadesTCheck" text="CAdES-T (RFC 3161 timestamp)" onAction="#handleCadesTimestampOptionChanged">
                                                                         <tooltip><Tooltip text="Requests a RFC 3161 timestamp over the CAdES signature. Requires a reachable TSA URL."/></tooltip>
                                                                     </CheckBox>
                                                                     <Region HBox.hgrow="ALWAYS"/>
                                                                     <Button text="Sign" onAction="#handleCMSSign" styleClass="action-button-primary"/>
                                                                     <Button text="Add LT Evidence..." onAction="#handleUpgradeCadesLt" styleClass="action-button-secondary">
                                                                         <tooltip><Tooltip text="Embed locally selected CRL files into an existing CAdES-T signature. No CRL is downloaded automatically."/></tooltip>
                                                                     </Button>
                                                                     <Button text="Verify" onAction="#handleCMSVerify" styleClass="action-button-secondary"/>
                                                                </HBox>
                                                                <HBox fx:id="cmsCadesTsaBox" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false">
                                                                    <Label text="CAdES-T TSA URL:"/>
                                                                    <TextField fx:id="cmsCadesTsaUrlField" promptText="https://your-tsa.example/" HBox.hgrow="ALWAYS"/>
                                                                </HBox>
                                                            </VBox>
                                                        </content>
                                                    </Tab>
                                                    <Tab text="Encryption (EnvelopedData)">
                                                        <content>
                                                            <VBox spacing="10" style="-fx-padding: 10;">
                                                                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 0 0 5 0;">
                                                                    <Label text="Source:" style="-fx-font-weight: bold;"/>
                                                                    <fx:define>
                                                                        <ToggleGroup fx:id="cmsEncryptSourceToggleGroup"/>
                                                                    </fx:define>
                                                                    <RadioButton fx:id="cmsEncryptSourceLocalRadio" text="Local PEM (Cert/Key)" toggleGroup="$cmsEncryptSourceToggleGroup" selected="true" onAction="#handleCMSEncryptSourceChanged"/>
                                                                    <RadioButton fx:id="cmsEncryptSourcePkcs11Radio" text="PKCS#11 Token" toggleGroup="$cmsEncryptSourceToggleGroup" onAction="#handleCMSEncryptSourceChanged"/>
                                                                </HBox>

                                                                <GridPane fx:id="cmsEncryptLocalGrid" hgap="10" vgap="10">
                                                                    <Label text="Recipient Certificate (for Encrypt):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                                    <TextArea fx:id="cmsEncryptCertArea" promptText="-----BEGIN CERTIFICATE-----..." prefHeight="80" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS" style="-fx-font-family: 'Monospaced';"/>

                                                                    <Label text="Recipient Private Key (for Decrypt):" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                                                    <TextArea fx:id="cmsDecryptKeyArea" promptText="-----BEGIN PRIVATE KEY-----..." prefHeight="80" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS" style="-fx-font-family: 'Monospaced';"/>
                                                                    <columnConstraints>
                                                                        <ColumnConstraints percentWidth="50"/>
                                                                        <ColumnConstraints percentWidth="50"/>
                                                                    </columnConstraints>
                                                                </GridPane>

                                                                <HBox fx:id="cmsEncryptPkcs11Box" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
                                                                    <Label text="Token Key Alias:"/>
                                                                    <ComboBox fx:id="cmsEncryptKeyAliasCombo" prefWidth="250" />
                                                                    <Button text="Load Token Keys" onAction="#handleLoadCMSEncryptKeys" />
                                                                </HBox>

                                                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                                                     <Button text="Encrypt" onAction="#handleCMSEncrypt" styleClass="action-button-warning"/>
                                                                     <Button text="Decrypt" onAction="#handleCMSDecrypt" styleClass="action-button-danger"/>
                                                                </HBox>
                                                            </VBox>
                                                        </content>
                                                    </Tab>
                                                </tabs>
                                            </TabPane>

                                            <Label text="Output / Result:"/>
                                            <TextArea fx:id="cmsOutputArea" editable="false" prefHeight="80" style="-fx-font-family: 'Monospaced';"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- CMS INSPECTOR -->
                                    <fx:include fx:id="cmsInspector" source="cms_inspector.fxml" />

                                    <!-- ASN.1 DECODER -->
                                    <fx:include fx:id="asn1" source="asn1.fxml" />
                                </panes>
                            </Accordion>
                        </VBox>

                        <!-- CIPHER CONTENT -->
                        <VBox fx:id="cipherContainer" managed="false" visible="false" spacing="10" styleClass="content-container-vbox">
                            <Label text="Data Encryption &amp; Decryption" styleClass="content-title-label" style="-fx-padding: 0 0 10 5;"/>
                            <Accordion>
                                <panes>
                                    <!-- SYMMETRIC CIPHER -->
                                    <TitledPane text="🔒 Symmetric Cipher (AES, DES, etc.)" expanded="true">
                                        <VBox spacing="10" style="-fx-padding: 10;">
                                            <GridPane hgap="10" vgap="10">
                                                <columnConstraints>
                                                    <ColumnConstraints percentWidth="20"/>
                                                    <ColumnConstraints percentWidth="80"/>
                                                </columnConstraints>

                                                <Label text="Algorithm:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                <ComboBox fx:id="symmetricAlgorithmCombo" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                                <Label text="Mode:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                                <ComboBox fx:id="cipherModeCombo" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                                <Label text="Padding:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                                <ComboBox fx:id="paddingCombo" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                                <Label text="Key Source:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3" alignment="CENTER_LEFT">
                                                    <ComboBox fx:id="symKeySourceCombo" prefWidth="145" />
                                                    <StackPane HBox.hgrow="ALWAYS">
                                                        <TextField fx:id="symmetricKeyField" promptText="Hex Key" style="-fx-font-family: 'Monospaced';"/>
                                                        <ComboBox fx:id="symHsmKeyCombo" maxWidth="Infinity" visible="false" managed="false"/>
                                                    </StackPane>
                                                    <Button text="Save to Lab" onAction="#handleSaveSymKeyToHsm" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                                                </HBox>

                                                <Label text="IV / Nonce:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                                <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="4" alignment="CENTER_LEFT">
                                                    <TextField fx:id="ivField" promptText="Hex IV" HBox.hgrow="ALWAYS" style="-fx-font-family: 'Monospaced';"/>
                                                    <Button text="Generate" onAction="#handleGenerateIV" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                                                </HBox>

                                                <Label text="Auth Tag (GCM):" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                                <TextField fx:id="gcmTagField" promptText="Hex Tag (16 bytes) - for GCM/Poly1305 Decryption" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-font-family: 'Monospaced';"/>

                                                <Label text="AAD (Optional):" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                                                <TextField fx:id="aadField" promptText="Hex AAD (Additional Authenticated Data)" GridPane.columnIndex="1" GridPane.rowIndex="6" style="-fx-font-family: 'Monospaced';"/>
                                            </GridPane>

                                            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                                                <Button text="Encrypt" onAction="#handleSymmetricEncrypt" styleClass="action-button"/>
                                                <Button text="Decrypt" onAction="#handleSymmetricDecrypt" styleClass="action-button"/>
                                            </HBox>
                                        </VBox>
                                    </TitledPane>

                                    <!-- STREAMING FILE CIPHER -->
                                    <TitledPane text="📁 File Cipher (Streaming)" expanded="false">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Processes the file in chunks. GCM and ChaCha20-Poly1305 use a detached 16-byte tag." style="-fx-font-size: 10px; -fx-text-fill: #666;" wrapText="true"/>
                                            <ComboBox fx:id="fileCipherAlgorithmCombo" prefWidth="250" style="-fx-font-size: 11px;"/>
                                            <HBox spacing="5">
                                                <TextField fx:id="fileCipherSourceField" promptText="Source file path" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                                                <Button text="…" onAction="#handleChooseFileCipherSource" styleClass="secondary-button"/>
                                            </HBox>
                                            <HBox spacing="5">
                                                <TextField fx:id="fileCipherDestinationField" promptText="Output file path" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                                                <Button text="…" onAction="#handleChooseFileCipherDestination" styleClass="secondary-button"/>
                                            </HBox>
                                            <HBox spacing="5">
                                                <TextField fx:id="fileCipherTagField" promptText="Detached AEAD tag path (.tag; required for GCM / ChaCha)" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                                                <Button text="…" onAction="#handleChooseFileCipherTag" styleClass="secondary-button"/>
                                            </HBox>
                                            <TextField fx:id="fileCipherKeyField" promptText="Key in hexadecimal" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                                            <HBox spacing="5">
                                                <TextField fx:id="fileCipherNonceField" promptText="IV / nonce in hexadecimal (fresh value for AEAD encryption)" HBox.hgrow="ALWAYS" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                                                <Button text="Generate" onAction="#handleGenerateFileCipherNonce" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                                            </HBox>
                                            <TextField fx:id="fileCipherAadField" promptText="AAD in hexadecimal (optional, AEAD only)" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                                            <CheckBox fx:id="fileCipherLinesCheck" text="Process each UTF-8 line independently (GCM/ChaCha: fresh nonce per line; CBC: supplied IV for all lines)" wrapText="true" style="-fx-font-size: 10px;"/>
                                            <HBox spacing="6" alignment="CENTER_LEFT">
                                                <Label text="Line output:" style="-fx-font-size: 10px;"/>
                                                <ComboBox fx:id="fileCipherLineEncodingCombo" prefWidth="120" style="-fx-font-size: 10px;"/>
                                                <Label text="Text:" style="-fx-font-size: 10px;"/>
                                                <ComboBox fx:id="fileCipherLineCharsetCombo" prefWidth="180" style="-fx-font-size: 10px;"/>
                                            </HBox>
                                            <CheckBox fx:id="fileCipherCompactCbcCheck" text="Write line records without header (compact format)" style="-fx-font-size: 10px;"/>
                                            <HBox spacing="8">
                                                <Button text="Encrypt File" onAction="#handleFileCipherEncrypt" styleClass="action-button"/>
                                                <Button text="Decrypt File" onAction="#handleFileCipherDecrypt" styleClass="action-button"/>
                                            </HBox>
                                            <TextArea fx:id="fileCipherResultArea" editable="false" prefHeight="100" wrapText="true"
                                                      style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                                        </VBox>
                                    </TitledPane>

                                    <TitledPane text="🔐 OpenPGP (GPG compatible)" expanded="false">
                                        <content>
                                            <fx:include fx:id="openPgpContainer" source="openpgp.fxml"/>
                                        </content>
                                    </TitledPane>

                                    <!-- ASYMMETRIC CIPHER -->
                                    <TitledPane text="🔑 Asymmetric Cipher (RSA)" expanded="false">
                                        <VBox spacing="10" style="-fx-padding: 10;">
                                            <Label text="RSA Operation using loaded keys (load keys from Keys tab OR enter manually below)" style="-fx-font-style: italic; -fx-text-fill: gray;"/>

                                            <GridPane hgap="10" vgap="10">
                                                 <Label text="Padding:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                 <ComboBox fx:id="rsaPaddingCombo" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                                 <Label text="Input Format:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                                 <ComboBox fx:id="asymmetricInputFormatCombo" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                                 <Label text="Output Format:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                                 <ComboBox fx:id="asymmetricOutputFormatCombo" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                            </GridPane>

                                            <Separator orientation="HORIZONTAL"/>



                                            <VBox spacing="5">
                                                <Label text="Public Key (PEM or Hex):" style="-fx-font-size: 11px;"/>
                                                <TextArea fx:id="publicKeyArea" prefHeight="60" wrapText="true" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                                                <HBox spacing="5">
                                                    <Button text="Read from Text" onAction="#handleLoadPublicKey" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                                    <Button text="Load from File..." onAction="#handleReadPublicKeyFile" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                                </HBox>
                                            </VBox>

                                            <VBox spacing="5">
                                                <Label text="Private Key (PEM or Hex):" style="-fx-font-size: 11px;"/>
                                                <TextArea fx:id="privateKeyArea" prefHeight="60" wrapText="true" style="-fx-font-family: 'Monospaced'; -fx-font-size: 11px;"/>
                                                <HBox spacing="5">
                                                    <Button text="Read from Text" onAction="#handleLoadPrivateKey" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                                    <Button text="Load from File..." onAction="#handleReadPrivateKeyFile" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                                </HBox>
                                            </VBox>

                                            <Separator orientation="HORIZONTAL"/>

                                            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                                                <Button text="Encrypt (Public Key)" onAction="#handleAsymmetricEncrypt" styleClass="action-button"/>
                                                <Button text="Decrypt (Private Key)" onAction="#handleAsymmetricDecrypt" styleClass="action-button"/>
                                            </HBox>
                                        </VBox>
                                    </TitledPane>
                                </panes>
                            </Accordion>

                            <Separator orientation="HORIZONTAL"/>

                            <VBox spacing="5" style="-fx-padding: 5;">
                                <Label text="Input Data:"/>
                                <TextArea fx:id="cipherInputArea" prefHeight="120" wrapText="true" style="-fx-font-family: 'Monospaced';"/>

                                <HBox spacing="10" alignment="CENTER">
                                    <Label text="⬇" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: gray;"/>
                                </HBox>

                                <Label text="Output Result:"/>
                                <TextArea fx:id="cipherOutputArea" prefHeight="120" editable="false" wrapText="true" style="-fx-font-family: 'Monospaced';"/>
                            </VBox>
                        </VBox>

                        <!-- Authentication Container -->
                        <VBox fx:id="authenticationContainer" managed="false" visible="false" spacing="0">
                            <Accordion>
                                <panes>
                                    <!-- DIGITAL SIGNATURES -->
                                    <TitledPane text="🔏 Digital Signatures" expanded="true">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Algorithm:" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="signatureAlgorithmCombo" prefWidth="200" style="-fx-font-size: 11px;"/>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Label text="Keys (PEM format):" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                            <TabPane tabClosingPolicy="UNAVAILABLE" prefHeight="220">
                                                <Tab text="Private Key">
                                                    <VBox spacing="5" style="-fx-padding: 8;">
                                                        <TextArea fx:id="signaturePrivateKeyArea" promptText="Paste Private Key PEM here..."
                                                                  wrapText="true" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;" VBox.vgrow="ALWAYS"/>
                                                        <Button text="Load Private Key..." onAction="#handleLoadSignPrivateKey"
                                                                    styleClass="secondary-button" maxWidth="Infinity" style="-fx-font-size: 10px;"/>
                                                    </VBox>
                                                </Tab>
                                                <Tab text="Public Key">
                                                    <VBox spacing="5" style="-fx-padding: 8;">
                                                        <TextArea fx:id="signaturePublicKeyArea" promptText="Paste Public Key PEM here..."
                                                                  wrapText="true" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;" VBox.vgrow="ALWAYS"/>
                                                        <Button text="Load Public Key..." onAction="#handleLoadSignPublicKey"
                                                                    styleClass="secondary-button" maxWidth="Infinity" style="-fx-font-size: 10px;"/>
                                                    </VBox>
                                                </Tab>
                                            </TabPane>
                                            <Label fx:id="signatureKeyStatusLabel" text="Ready to sign/verify"
                                                   style="-fx-font-size: 10px; -fx-text-fill: #666;"/>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Button text="Sign" onAction="#handleSign"
                                                    styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Label text="Verify Signature:" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                            <TextField fx:id="signatureVerifyField" promptText="Paste signature to verify (Format must match 'Output Format' selection)"
                                                      style="-fx-font-size: 11px;"/>
                                            <Button text="Verify Signature" onAction="#handleVerify"
                                                    styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                            <Label text="ℹ️ Sign: data in Input → signature in Output"
                                                   style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- MESSAGE AUTHENTICATION CODES (MAC) -->
                                    <TitledPane text="🔐 Message Authentication Codes (MAC)">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Algorithm:" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="authMacAlgorithmCombo" prefWidth="200" style="-fx-font-size: 11px;"/>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Label text="Key Source:" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <ComboBox fx:id="macKeySourceCombo" prefWidth="145" style="-fx-font-size: 11px;" />
                                                <StackPane HBox.hgrow="ALWAYS">
                                                    <TextField fx:id="authMacKeyField" promptText="Enter MAC key in hexadecimal"
                                                              style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
                                                    <ComboBox fx:id="macHsmKeyCombo" maxWidth="Infinity" visible="false" managed="false" style="-fx-font-size: 11px;"/>
                                                </StackPane>
                                                <Button text="Save to Lab" onAction="#handleSaveMacKeyToHsm" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                                            </HBox>
                                            <Label fx:id="authMacKeyInfoLabel" text="Key size depends on algorithm"
                                                   style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                            <TextField fx:id="authMacNonceField" promptText="Nonce / IV in hexadecimal (GMAC only, unique per key)"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Label text="Truncation (bytes):" style="-fx-font-size: 11px;"/>
                                            <HBox spacing="6" alignment="CENTER_LEFT">
                                                <ComboBox fx:id="authMacTruncationCombo" prefWidth="100" style="-fx-font-size: 11px;"/>
                                                <Label text="(0 = full MAC)" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                            </HBox>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Button text="Generate MAC" onAction="#handleGenerateMAC"
                                                    styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                            <Separator style="-fx-padding: 3 0;"/>

                                            <Label text="Verify MAC:" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                            <TextField fx:id="authMacVerifyField" promptText="Paste MAC to verify"
                                                      style="-fx-font-size: 11px;"/>
                                            <Button text="Verify MAC" onAction="#handleVerifyMAC"
                                                    styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                            <Label text="ℹ️ Generate: data in Input → MAC in Output"
                                                   style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
                                        </VBox>
                                    </TitledPane>
                                </panes>
                            </Accordion>

                            <Separator orientation="HORIZONTAL"/>

                            <VBox spacing="5" style="-fx-padding: 5;">
                                <Label text="Input Data:"/>
                                <TextArea fx:id="authInputArea" prefHeight="120" wrapText="true" style="-fx-font-family: 'Monospaced';"/>

                                <HBox spacing="10" alignment="CENTER">
                                    <Label text="⬇" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: gray;"/>
                                </HBox>

                                <Label text="Output Result:"/>
                                <TextArea fx:id="authOutputArea" prefHeight="120" editable="false" wrapText="true" style="-fx-font-family: 'Monospaced';"/>
                            </VBox>
                        </VBox>

                        <!-- Payments Container -->
                        <VBox fx:id="paymentsContainer" managed="false" visible="false" spacing="0">
                            <Accordion>
                                <panes>
                                    <!-- CVV OPERATIONS -->
                                    <TitledPane text="💳 CVV Operations (CVV/CVV2/iCVV)" expanded="true">
                                        <VBox spacing="8" style="-fx-padding: 10;">
                                            <Label text="Type:" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="cvvTypeCombo" prefWidth="250" style="-fx-font-size: 11px;"/>

                                            <Separator style="-fx-padding: 5 0;"/>

                                            <GridPane hgap="8" vgap="4">
                                                <columnConstraints>
                                                    <ColumnConstraints minWidth="90" prefWidth="90"/>
                                                    <ColumnConstraints hgrow="ALWAYS"/>
