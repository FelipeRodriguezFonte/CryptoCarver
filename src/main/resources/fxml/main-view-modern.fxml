                        <!-- Certificates Operations -->
                        <VBox fx:id="certificatesContainer" managed="false" visible="false" spacing="0">
                            <Accordion>
                                <panes>
                                    <!-- GENERATE CERTIFICATE -->
                                    <TitledPane text="📜 Generate Certificate" expanded="true">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <GridPane hgap="6" vgap="4">
                                                <columnConstraints>
                                                    <ColumnConstraints minWidth="80" prefWidth="80"/>
                                                    <ColumnConstraints hgrow="ALWAYS"/>
                                                </columnConstraints>

                                                <Label text="CN:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certCNField" promptText="localhost"
                                                          GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Organization:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certOrgField" promptText="Crypto Org"
                                                          GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Org. Unit:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certOUField" promptText="IT Security"
                                                          GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Country:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certCountryField" promptText="ES" prefWidth="60"
                                                          GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="State:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certStateField" promptText="State/Province"
                                                          GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Locality:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certLocalityField" promptText="City"
                                                          GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Email:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certEmailField" promptText="Optional"
                                                          GridPane.rowIndex="6" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Validity (days):" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certValidityField" text="365" prefWidth="80"
                                                          GridPane.rowIndex="7" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Key Type:" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <ComboBox fx:id="certKeyTypeCombo" prefWidth="120"
                                                         GridPane.rowIndex="8" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>

                                                <Label text="Sign Algorithm:" GridPane.rowIndex="9" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <ComboBox fx:id="certSignAlgoCombo" prefWidth="150"
                                                         GridPane.rowIndex="9" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                                <Label text="SAN DNS:" GridPane.rowIndex="10" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certSanDnsField" promptText="Comma-separated (e.g. api.example.test)" GridPane.rowIndex="10" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                                <Label text="SAN IP:" GridPane.rowIndex="11" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="certSanIpField" promptText="Comma-separated (e.g. 127.0.0.1)" GridPane.rowIndex="11" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                            </GridPane>

                                            <HBox spacing="8">
                                                <Button text="Generate Certificate" onAction="#handleGenerateCertificate" styleClass="action-button" style="-fx-font-size: 11px;"/>
                                                <Button text="Generate CSR" onAction="#handleGenerateCSR" styleClass="secondary-button" style="-fx-font-size: 11px;"/>
                                            </HBox>
                                            <CheckBox fx:id="certRootCaCheck" text="Generate as laboratory Root CA (CA:TRUE, keyCertSign)" style="-fx-font-size: 10px; -fx-text-fill: #9a3412;"/>

                                            <TextArea fx:id="certOutputArea" prefHeight="200" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                      promptText="Certificate will appear here..."
                                                      managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- ISSUE FROM CSR -->
                                    <TitledPane text="🏛 Issue Certificate from CSR (Laboratory CA)">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Validates the CSR signature before issuing. Use only a laboratory CA key." wrapText="true" style="-fx-font-size: 10px; -fx-text-fill: #9a3412;"/>
                                            <TextArea fx:id="certIssueCsrArea" prefHeight="80" wrapText="true" promptText="PKCS#10 CSR PEM"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <TextArea fx:id="certIssueCaCertArea" prefHeight="80" wrapText="true" promptText="Issuer Root CA certificate PEM"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <TextArea fx:id="certIssueCaKeyArea" prefHeight="80" wrapText="true" promptText="Issuer Root CA private key PEM"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <HBox spacing="6">
                                                <TextField fx:id="certIssueValidityField" text="90" prefWidth="80" promptText="Days"/>
                                                <TextField fx:id="certIssueSignatureField" text="Automatic" promptText="Automatic or issuer signature algorithm" HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="6" alignment="CENTER_LEFT">
                                                <Label text="Profile:" style="-fx-font-size: 10px;"/>
                                                <ComboBox fx:id="certIssueProfileCombo" promptText="Select Profile"/>
                                                <Label text="Path length (CA):" style="-fx-font-size: 10px;"/>
                                                <TextField fx:id="certIssuePathLengthField" text="0" prefWidth="45"/>
                                            </HBox>
                                            <Button text="Issue Laboratory Certificate" onAction="#handleIssueCertificateFromCsr" styleClass="action-button" maxWidth="220" style="-fx-font-size: 11px;"/>
                                            <TextArea fx:id="certIssueResultArea" prefHeight="180" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- PARSE CERTIFICATE -->
                                    <TitledPane text="🔍 Parse Certificate">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Paste PEM Certificate:" style="-fx-font-size: 11px;"/>
                                            <TextArea fx:id="certInputArea" prefHeight="100" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                      promptText="Paste certificate in PEM format..."/>

                                            <Button text="Parse Certificate" onAction="#handleParseCertificate"
                                                    styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                            <TextArea fx:id="certParseResultArea" prefHeight="200" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                      promptText="Parse results will appear here..."
                                                      managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- COMPARE CERTIFICATES -->
                                    <TitledPane text="⚖ Compare Certificates">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <TextArea fx:id="certCompareLeftArea" prefHeight="85" wrapText="true" promptText="Left X.509 certificate PEM"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <TextArea fx:id="certCompareRightArea" prefHeight="85" wrapText="true" promptText="Right X.509 certificate PEM"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <Button text="Compare Certificates" onAction="#handleCompareCertificates" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                                            <TextArea fx:id="certCompareResultArea" prefHeight="180" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                        </VBox>
                                    </TitledPane>

                                    <TitledPane text="🛡 Validate Certificate">
                                    <content>
                                        <VBox spacing="10" styleClass="content-pane">
                                            <Label text="Certificate (PEM)" styleClass="section-header"/>
                                            <TextArea fx:id="valCertInput" promptText="Paste X.509 Certificate..." prefRowCount="5" wrapText="true" styleClass="code-area"/>

                                            <Label text="Issuer Certificate (Optional)" styleClass="section-header"/>
                                            <TextArea fx:id="valIssuerInput" promptText="Paste Issuer Certificate (for signature verification)..." prefRowCount="5" wrapText="true" styleClass="code-area"/>

                                            <Button text="Validate Certificate" onAction="#handleValidateCertificate" styleClass="action-button"/>

                                            <Label text="Validation Report" styleClass="section-header"/>
                                            <TextArea fx:id="valResultArea" editable="false" prefRowCount="5" wrapText="true" styleClass="code-area"/>
                                        </VBox>
                                    </content>
                                </TitledPane>
                                <TitledPane text="🔗 Validate Chain">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Paste Certificate Chain (PEM sequence - End Entity first):" style="-fx-font-size: 11px;"/>
                                            <TextArea fx:id="chainInputArea" prefHeight="100" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                      promptText="-----BEGIN CERTIFICATE-----..."/>
                                            <Label text="Optional CRLs (PEM sequence):" style="-fx-font-size: 11px;"/>
                                            <TextArea fx:id="chainCrlInputArea" prefHeight="70" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                      promptText="-----BEGIN X509 CRL-----..."/>

                                            <Button text="Validate Chain" onAction="#handleValidateCertificateChain"
                                                    styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                                            <TextArea fx:id="chainResultArea" prefHeight="150" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"
                                                      promptText="Validation results will appear here..."
                                                      managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- CRL MANAGEMENT -->
                                    <TitledPane text="🚫 CRL Management">
                                        <VBox spacing="6" style="-fx-padding: 8;">
                                            <Label text="Generate or update an offline CRL." style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                                            <TextArea fx:id="crlIssuerCertArea" prefHeight="70" wrapText="true" promptText="Issuer Root CA certificate PEM" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <TextArea fx:id="crlIssuerKeyArea" prefHeight="70" wrapText="true" promptText="Issuer Root CA private key PEM" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <TextArea fx:id="crlExistingCrlArea" prefHeight="70" wrapText="true" promptText="Existing CRL PEM (optional)" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;"/>
                                            <HBox spacing="6" alignment="CENTER_LEFT">
                                                <TextField fx:id="crlRevokeSerialField" promptText="Serial Number to Revoke (Hex)"/>
