                                                <Label text="Amount:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="amountField" promptText="000000000100"
                                                          GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="Amount Other:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="amountOtherField" promptText="000000000000"
                                                          GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="Currency:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="currencyField" promptText="0978 (EUR)"
                                                          GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="Country:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="countryField" promptText="0724 (ES)"
                                                          GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <!-- ATC Field retained for UI context but excluded from default BP-Tools structure unless user adds it to Raw Data -->
                                                <Label text="ATC (Info):" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="atcARQCField" promptText="0001"
                                                          GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="TVR:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="tvrField" promptText="0000000000"
                                                          GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="Date (YYMMDD):" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="txDateField" promptText="250101"
                                                          GridPane.rowIndex="6" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="Type:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="txTypeField" promptText="00"
                                                          GridPane.rowIndex="7" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="UN:" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="unField" promptText="Unpredictable Number (4 bytes)"
                                                          GridPane.rowIndex="8" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="ICC Data:" GridPane.rowIndex="9" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <TextField fx:id="iccDataField" promptText="Optional (Tag 9F10?)"
                                                          GridPane.rowIndex="9" GridPane.columnIndex="1" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                                <Label text="Padding:" GridPane.rowIndex="10" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                <ComboBox fx:id="arqcPaddingMethodCombo" prefWidth="250"
                                                          GridPane.rowIndex="10" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                            </GridPane>

                                            <Button text="Generate ARQC" onAction="#handleGenerateARQC"
                                                    styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>

                                            <TextArea fx:id="arqcResultArea" prefHeight="80" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;" managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- ARPC GENERATION -->
                                    <TitledPane text="🔄 ARQC Validation &amp; ARPC">
                                        <VBox spacing="8" style="-fx-padding: 10;">
                                            <Label text="Session Key (Hex):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="skARPCField" promptText="16 bytes Session Key"
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                            <Label text="ARQC (from card):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="arqcField" promptText="8 bytes ARQC"
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                            <Label text="Response Code (ARC):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="arcField" promptText="e.g. 3030 (Approved)"
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                            <Label text="CSU (Optional, for Method 2):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="csuField" promptText="4 bytes Card Status Update"
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                            <Label text="Prop. Auth. Data (Optional):" style="-fx-font-size: 11px;"/>
                                            <TextField fx:id="propAuthDataField" promptText="Proprietary Authentication Data (Hex)"
                                                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"/>

                                            <Label text="Method:" style="-fx-font-size: 11px;"/>
                                            <ComboBox fx:id="arpcMethodCombo" prefWidth="250" style="-fx-font-size: 11px;"/>

                                            <HBox spacing="10">
                                                <Button text="Generate ARPC" onAction="#handleGenerateARPC"
                                                        styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                                <Button text="Verify ARQC (Sim)" onAction="#handleVerifyARQC"
                                                        styleClass="secondary-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                            </HBox>

                                            <TextArea fx:id="arpcResultArea" prefHeight="80" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;" managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>

                                    <!-- TRACK 2 DATA -->
                                    <TitledPane text="🎞 Track 2 Data">
                                        <VBox spacing="8" style="-fx-padding: 10;">
                                            <TabPane tabClosingPolicy="UNAVAILABLE">
                                                <Tab text="Encode">
                                                    <VBox spacing="8" style="-fx-padding: 8;">
                                                        <Label text="PAN:" style="-fx-font-size: 11px;"/>
                                                        <TextField fx:id="panTrack2Field" promptText="Primary Account Number" style="-fx-font-size: 11px;"/>

                                                        <GridPane hgap="8" vgap="4">
                                                            <columnConstraints>
                                                                <ColumnConstraints percentWidth="50"/>
                                                                <ColumnConstraints percentWidth="50"/>
                                                            </columnConstraints>
                                                            <Label text="Expiry (YYMM):" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                                                            <TextField fx:id="expiryTrack2Field" promptText="2512" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>

                                                            <Label text="Service Code:" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                                            <TextField fx:id="serviceCodeFieldTrack2" promptText="201" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                                                        </GridPane>

                                                        <Label text="Discretionary Data:" style="-fx-font-size: 11px;"/>
                                                        <TextField fx:id="discretionaryDataField" promptText="Optional" style="-fx-font-size: 11px;"/>

                                                        <Button text="Encode Track 2" onAction="#handleEncodeTrack2"
                                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                                    </VBox>
                                                </Tab>
                                                <Tab text="Decode">
                                                    <VBox spacing="8" style="-fx-padding: 8;">
                                                        <Label text="Track 2 Hex / String:" style="-fx-font-size: 11px;"/>
                                                        <TextField fx:id="track2InputField" promptText="Paste Track 2 data" style="-fx-font-size: 11px;"/>

                                                        <Button text="Decode Track 2" onAction="#handleDecodeTrack2"
                                                                styleClass="action-button" maxWidth="150" style="-fx-font-size: 11px;"/>
                                                    </VBox>
                                                </Tab>
                                            </TabPane>

                                            <TextArea fx:id="track2ResultArea" prefHeight="100" editable="false" wrapText="true"
                                                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 10px;" managed="false" visible="false"/>
                                        </VBox>
                                    </TitledPane>
                                </panes>
                            </Accordion>
                        </VBox>

                        <!-- Generic Utilities Container -->
                        <!-- GENERIC CONTENT (Hashing, Encoding, etc) -->
                <fx:include fx:id="genericContainer" source="generic.fxml" />

                    <!-- Recent Operations / History -->
                    <fx:include fx:id="historyView" source="history.fxml" />
                    <fx:include fx:id="clipboardShelf" source="clipboard_shelf.fxml" />

                    <!-- Post-Quantum Cryptography Container -->
                    <fx:include source="pqc.fxml" fx:id="postQuantumContainer" />

                    <!-- XML Security Container -->
                    <fx:include source="xml_security.fxml" fx:id="xmlSecurityContainer" />

                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Inspector Panel (right, collapsible) -->
            <VBox fx:id="inspectorPanel" minWidth="280" maxWidth="280" styleClass="inspector-panel">

                <!-- Inspector Header -->
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="inspector-header-bar">
                    <Label text="Inspector" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#handleToggleInspector" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="0">

                        <!-- Input/Output Section -->
                        <VBox spacing="8" style="-fx-padding: 12;">
                            <GridPane hgap="10" vgap="5">
                                <Label text="Input Bytes:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="inspector-label-small"/>
                                <Label fx:id="inputBytesLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="inspector-value"/>

                                <Label text="Output Bytes:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="inspector-label-small"/>
                                <Label fx:id="outputBytesLabel" text="32" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="inspector-value"/>

                                <columnConstraints>
                                    <ColumnConstraints minWidth="100"/>
                                    <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
                                </columnConstraints>
                            </GridPane>

                            <Separator styleClass="separator-horizontal"/>

                            <VBox spacing="4">
                                <Label text="Algorithm:" styleClass="inspector-label-small"/>
                                <Label fx:id="operationLabel" text="HKDF-SHA256" style="-fx-font-weight: bold;"/>
                            </VBox>

                             <Separator styleClass="separator-horizontal"/>

                             <!-- Dynamic Details -->
                             <VBox fx:id="inspectorDetailsContainer" spacing="4">
                                 <!-- Details will be added here programmatically -->
                             </VBox>
                        </VBox>

                        <!-- Security Tips Section -->
                        <HBox styleClass="inspector-section-header">
                            <Label text="Security Tips" styleClass="inspector-section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="&lt;" style="-fx-text-fill: white; -fx-font-size: 10px;"/>
                        </HBox>

                        <VBox style="-fx-padding: 12;">
                            <VBox styleClass="warning-box" spacing="5">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="⚠️" style="-fx-font-size: 16px;"/>
                                    <Label text="Warning" styleClass="warning-title"/>
                                </HBox>
                                <Label fx:id="securityTipLabel" text="No salt provided, HKDF is less secure! Consider using a random salt."
                                       wrapText="true" styleClass="warning-text"/>
                            </VBox>
                        </VBox>

                        <!-- History Section -->
                        <HBox styleClass="inspector-section-header">
                            <Label text="History" styleClass="inspector-section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Export JSON" onAction="#handleExportHistory" style="-fx-font-size: 10px; -fx-padding: 2 6; -fx-background-color: transparent; -fx-text-fill: #81c784; -fx-cursor: hand;">
                                <tooltip><Tooltip text="Export the complete operation history as JSON"/></tooltip>
                            </Button>
                            <Button text="Clear" onAction="#handleClearHistory" style="-fx-font-size: 10px; -fx-padding: 2 6; -fx-background-color: transparent; -fx-text-fill: #90caf9; -fx-cursor: hand;"/>
                        </HBox>

                        <VBox fx:id="historyContainer" spacing="4" style="-fx-padding: 8;">
                            <!-- Example Items -->
                            <HBox styleClass="history-item" spacing="8" alignment="CENTER_LEFT">
                                <Label text="🕒"/>
                                <VBox>
                                    <Label text="HKDF SHA256 32B" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Rerun" style="-fx-font-size: 10px; -fx-padding: 2 6;"/>
                            </HBox>

                            <HBox styleClass="history-item" spacing="8" alignment="CENTER_LEFT">
                                <Label text="🕒"/>
                                <VBox>
                                    <Label text="AES-GCM Encrypt" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Rerun" style="-fx-font-size: 10px; -fx-padding: 2 6;"/>
                            </HBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>

        </HBox>
    </center>

    <!-- Status Bar -->
    <bottom>
        <HBox styleClass="status-bar" spacing="10">
            <Label fx:id="statusLabel" text="Ready" styleClass="status-label-main"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Java 21 | JavaFX 21 | BouncyCastle" styleClass="status-label-info"/>
        </HBox>
    </bottom>

</BorderPane>
