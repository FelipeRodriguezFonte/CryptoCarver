<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TitledPane fx:id="asn1Pane" text="🔍 ASN.1 Decoder" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cryptoforge.ui.ASN1Controller">
    <content>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <TabPane fx:id="asn1TabPane" tabClosingPolicy="UNAVAILABLE">
                    <tabs>
                        <Tab text="Decode">
                            <content>
                                <VBox spacing="10.0" style="-fx-padding: 10;">
                                    <children>
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="40.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="60.0" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                            </rowConstraints>
                                            <children>
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label styleClass="section-label" text="Input Format" />
                                                        <ComboBox fx:id="asn1InputFormatCombo" maxWidth="1.7976931348623157E308" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label styleClass="section-label" text="Example / Type" />
                                                        <ComboBox fx:id="asn1TypeCombo" maxWidth="1.7976931348623157E308" onAction="#handleLoadASN1Example" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>

                                        <Label styleClass="section-label" text="ASN.1 Data (Hex, Base64, or PEM)" />
                                        <TextArea fx:id="asn1InputArea" prefHeight="100.0" promptText="Paste ASN.1 data here..." wrapText="true" style="-fx-font-family: 'Monospaced';"/>

                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#handleParseASN1" styleClass="action-button" text="Parse ASN.1" />
                                                <Button mnemonicParsing="false" onAction="#handleClearASN1" text="Clear" />
                                                <Button mnemonicParsing="false" onAction="#handleExportASN1Tree" text="Export Tree" />
                                                <Button mnemonicParsing="false" onAction="#handleExportASN1Json" text="Export JSON" />
                                                <Button mnemonicParsing="false" onAction="#handleExportASN1Markdown" text="Export Markdown" />
                                                <Button mnemonicParsing="false" onAction="#handleLoadASN1OidRegistry" text="Load OID Registry" />
                                                <Button mnemonicParsing="false" onAction="#handleCanonicalizeASN1Der" text="Canonicalize DER" />
                                                <CheckBox fx:id="asn1StrictDerCheck" text="Strict DER Mode" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="asn1StatusLabel" text="Ready" />
                                            </children>
                                        </HBox>

                                        <SplitPane dividerPositions="0.6" orientation="VERTICAL" VBox.vgrow="ALWAYS">
                                            <items>
                                                <VBox>
                                                    <children>
                                                        <Label styleClass="section-label" text="Structure Tree" />
                                                        <TreeView fx:id="asn1TreeView" prefHeight="200.0" VBox.vgrow="ALWAYS" />
                                                    </children>
                                                </VBox>
                                                <VBox>
                                                    <children>
                                                        <Label styleClass="section-label" text="Details / Analysis" />
                                                        <TextArea fx:id="asn1DetailsArea" editable="false" prefHeight="80.0" wrapText="true" VBox.vgrow="ALWAYS" />
                                                    </children>
                                                </VBox>
                                            </items>
                                        </SplitPane>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>
                        <Tab text="Encode">
                            <content>
                                <VBox spacing="10.0" style="-fx-padding: 10;">
                                    <children>
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                                            </columnConstraints>
                                            <children>
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label styleClass="section-label" text="ASN.1 Type" />
                                                        <ComboBox fx:id="asn1EncodeTypeCombo" maxWidth="1.7976931348623157E308" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label styleClass="section-label" text="Value Format" />
                                                        <ComboBox fx:id="asn1EncodeInputFormatCombo" maxWidth="1.7976931348623157E308" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>

                                        <Label styleClass="section-label" text="Value (for Strings/Integers) or Hex Content (for Wrappers)" />
                                        <TextArea fx:id="asn1EncodeInputArea" prefHeight="100.0" promptText="Enter value to encode..." wrapText="true" style="-fx-font-family: 'Monospaced';"/>

                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#handleEncodeASN1" styleClass="action-button" text="Encode" />
                                                <Button mnemonicParsing="false" onAction="#handleCopyASN1Output" text="Copy Output" />
                                            </children>
                                        </HBox>

                                        <Label styleClass="section-label" text="Encoded Output (DER Hex)" />
                                        <TextArea fx:id="asn1EncodeOutputArea" editable="false" prefHeight="150.0" style="-fx-font-family: 'Monospaced';" wrapText="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>
            </children>
        </VBox>
    </content>
</TitledPane>
