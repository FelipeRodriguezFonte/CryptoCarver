<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="mainHistoryContainer" spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cryptoforge.ui.HistoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header: split in rows so every action stays readable on ordinary window widths. -->
    <VBox spacing="7">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #37474f;" text="Recent Operations" />
            <Label fx:id="historySummaryLabel" style="-fx-text-fill: #607d8b; -fx-font-size: 11px;" text="0 operations" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Values:" />
            <ComboBox fx:id="visibilityCombo" prefWidth="215.0">
                <tooltip>
                    <Tooltip text="Choose Unsafe lab to reveal all values. This also controls report and recipe export." />
                </tooltip>
            </ComboBox>
            <Label fx:id="unsafeVisibilityWarningLabel" style="-fx-text-fill: #c0392b; -fx-font-size: 10px;" text="⚠ Unsafe lab: sensitive values are visible" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Filter:" />
            <TextField fx:id="historyFilterField" prefWidth="220.0" promptText="Operation, date or property" />
            <Label text="Module:" />
            <ComboBox fx:id="historyModuleFilterCombo" prefWidth="145.0" promptText="All modules" />
            <Button onAction="#handleClearHistoryFilter" style="-fx-font-size: 11px; -fx-padding: 4 8;" text="Clear filters" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="compareBtn" onAction="#handleCompareHistory" style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Compare 2" />
            <Button onAction="#importOperationRecipe" style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Import Recipe" />
            <Button onAction="#handleClearHistory" style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Clear History" />
        </HBox>

        <FlowPane hgap="8.0" vgap="7.0" prefWrapLength="900.0">
            <Label style="-fx-text-fill: #607d8b; -fx-font-size: 11px;" text="The latest operation is selected automatically. Select a different row to export it." />
            <Button fx:id="openHistoryDetailBtn" onAction="#openSelectedHistoryDetail" style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Open Selected Value">
                <tooltip>
                    <Tooltip text="Open the complete value of the selected detail in the expanded viewer." />
                </tooltip>
            </Button>
            <Button fx:id="copyHistoryDetailBtn" onAction="#copySelectedHistoryDetail" style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Copy Selected Value" />
            <Button fx:id="exportJsonRecordBtn" onAction="#exportSelectedHistoryRecord" style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Export JSON Record">
                <tooltip>
                    <Tooltip text="Export the selected execution, including its input/output according to the Values policy." />
                </tooltip>
            </Button>
            <Button fx:id="exportVisibleJsonBtn" onAction="#exportVisibleHistoryRecords" style="-fx-background-color: #0277bd; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Export Visible JSON">
                <tooltip>
                    <Tooltip text="Export every operation currently shown by the filters, according to the Values policy." />
                </tooltip>
            </Button>
            <Button fx:id="exportReportBtn" onAction="#exportSelectedHistoryReport" style="-fx-background-color: #00897b; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Export Markdown Report">
                <tooltip>
                    <Tooltip text="Export the selected operation as Markdown using the selected values policy." />
                </tooltip>
            </Button>
            <Button fx:id="copyReportBtn" onAction="#copySelectedHistoryReport" style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Copy Markdown Report">
                <tooltip>
                    <Tooltip text="Copy a Markdown report using the selected values policy." />
                </tooltip>
            </Button>
            <Button fx:id="exportRecipeBtn" onAction="#exportSelectedHistoryRecipe" style="-fx-background-color: #0288d1; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 4 10;" text="Export JSON Recipe">
                <tooltip>
                    <Tooltip text="Export the selected operation as a reusable JSON recipe." />
                </tooltip>
            </Button>
        </FlowPane>
    </VBox>

    <!-- Content SplitPane -->
    <SplitPane dividerPositions="0.6" orientation="VERTICAL" VBox.vgrow="ALWAYS">
        <items>
            <!-- Top/Left: History Table -->
            <TableView fx:id="historyTable">
                <columns>
                    <TableColumn fx:id="timeCol" text="Time" />
                    <TableColumn fx:id="opCol" text="Operation" />
                    <TableColumn fx:id="actionCol" text="Action" />
                </columns>
            </TableView>

            <!-- Bottom/Right: Details -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #b0bec5;" text="Operation Details" />
                <TableView fx:id="detailsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameCol" text="Property" />
                        <TableColumn fx:id="valCol" text="Value" />
                        <TableColumn fx:id="classCol" maxWidth="80.0" text="Class" />
                    </columns>
                </TableView>
            </VBox>
        </items>
    </SplitPane>
</VBox>
