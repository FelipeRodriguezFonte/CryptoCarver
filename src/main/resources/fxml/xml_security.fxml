<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="xmlSecurityContainer" managed="false" visible="false" spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cryptoforge.ui.XMLSignatureController">
    <Accordion fx:id="xmlAccordion">
        <panes>
            <TitledPane text="📝 Sign XML (XAdES)" expanded="true">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="XML File to Sign:"/>
                    <HBox spacing="10">
                        <TextField fx:id="xmlSignInputPathField" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="..." onAction="#handleBrowseXMLSignInput"/>
                    </HBox>

                    <Label text="Signature Source:"/>
                    <HBox spacing="10">
                        <fx:define>
                            <ToggleGroup fx:id="xmlSignSourceToggleGroup"/>
                        </fx:define>
                        <RadioButton fx:id="xmlSignSourceLocalRadio" text="Local KeyStore / PEM" toggleGroup="$xmlSignSourceToggleGroup" selected="true" onAction="#handleXMLSignSourceChanged"/>
                        <RadioButton fx:id="xmlSignSourcePkcs11Radio" text="Connected PKCS#11 Token" toggleGroup="$xmlSignSourceToggleGroup" onAction="#handleXMLSignSourceChanged"/>
                    </HBox>

                    <VBox fx:id="xmlSignLocalKeyBox" spacing="8">
                        <Label fx:id="xmlSignKeyPathLabel" text="PKCS#12 / JKS / PEM KeyStore:"/>
                        <HBox spacing="10">
                            <TextField fx:id="xmlSignKeyPathField" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                            <Button text="..." onAction="#handleBrowseXMLKey"/>
                        </HBox>

                        <Label fx:id="xmlSignKeyPasswordLabel" text="KeyStore Password:"/>
                        <PasswordField fx:id="xmlSignKeyPasswordField" style="-fx-font-size: 11px;"/>
                    </VBox>

                    <Label text="Key Alias (Select Key):"/>
                    <HBox spacing="10">
                        <ComboBox fx:id="xmlSignKeyAliasCombo" prefWidth="250" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                        <Button text="Load Keys" onAction="#handleLoadXMLKeys" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                    </HBox>

                    <Label text="Signature Level:"/>
                    <ComboBox fx:id="xmlSignLevelCombo" prefWidth="250" style="-fx-font-size: 11px;"/>
                    <Label text="Signature Packaging:"/>
                    <ComboBox fx:id="xmlSignPackagingCombo" prefWidth="250" style="-fx-font-size: 11px;"/>

                    <Label text="TSA (required for T/LT/LTA):"/>
                    <HBox spacing="6">
                        <ComboBox fx:id="xmlSignTsaUrlCombo" editable="true" promptText="Select a preset or enter your corporate TSA URL" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Save TSA" onAction="#handleSaveTSA" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                        <Button text="Test TSA" onAction="#handleTestTSA" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                    </HBox>
                    <HBox spacing="6">
                        <ComboBox fx:id="xmlSignTsaAuthTypeCombo" promptText="Auth Type" prefWidth="100" style="-fx-font-size: 11px;"/>
                        <TextField fx:id="xmlSignTsaUserField" promptText="User" prefWidth="100" style="-fx-font-size: 11px;"/>
                        <PasswordField fx:id="xmlSignTsaPasswordField" promptText="Password/Token (Ephemeral)" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                    </HBox>
                    <HBox spacing="6">
                        <ComboBox fx:id="xmlSignTsaProfileCombo" promptText="Saved TSA profile" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Load" onAction="#handleLoadTSASavedProfile" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                        <Button text="Delete" onAction="#handleDeleteTSASavedProfile" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                    </HBox>
                    <HBox spacing="6">
                        <TextField fx:id="xmlSignTsaProfileNameField" promptText="Profile name" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Save Profile" onAction="#handleSaveTSASavedProfile" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                    </HBox>

                    <Button text="Sign XML" onAction="#handleSignXML" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                    <Label text="Signed XML Output:"/>
                    <TextArea fx:id="xmlSignOutputArea" prefHeight="200" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                    <Button text="Save Signed XML..." onAction="#handleSaveSignedXML" styleClass="secondary-button" maxWidth="180" style="-fx-font-size: 11px;"/>
                </VBox>
            </TitledPane>
            <TitledPane text="🔬 Inspect Signed XML">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="Signed XML to inspect (local structural analysis, no validation):"/>
                    <TextArea fx:id="xmlInspectInputArea" prefHeight="180" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                    <HBox spacing="8">
                        <Button text="Open XML..." onAction="#handleBrowseXMLInspectorInput" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                        <Button text="Inspect Signed XML" onAction="#handleInspectSignedXML" styleClass="action-button" style="-fx-font-size: 10px;"/>
                    </HBox>
                    <Label text="Signature structure report:"/>
                    <TextArea fx:id="xmlInspectReportArea" prefHeight="280" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                </VBox>
            </TitledPane>
            <TitledPane text="⏱ RFC 3161 Timestamp">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="File to timestamp:"/>
                    <HBox spacing="8"><TextField fx:id="xmlTimestampFileField" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/><Button text="Open..." onAction="#handleBrowseTimestampFile"/></HBox>
                    <Label text="Imprint hash:"/>
                    <ComboBox fx:id="xmlTimestampHashCombo" prefWidth="180" style="-fx-font-size: 11px;"/>
                    <Label text="TSA URL:"/>
                    <TextField fx:id="xmlTimestampUrlField" promptText="https://your-tsa.example/" style="-fx-font-size: 11px;"/>
                    <HBox spacing="8"><Button text="Request Timestamp" onAction="#handleRequestTimestamp" styleClass="action-button" style="-fx-font-size: 10px;"/><Button text="Save Token..." onAction="#handleSaveTimestampToken" styleClass="secondary-button" style="-fx-font-size: 10px;"/></HBox>
                    <Label text="Saved token to inspect/validate (optional):"/>
                    <HBox spacing="8"><TextField fx:id="xmlTimestampTokenField" promptText="Path to .tsq/.tst" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/><Button text="Open..." onAction="#handleBrowseTimestampToken"/></HBox>
                    <HBox spacing="8">
                        <TextField fx:id="xmlTimestampTrustStoreField" promptText="Truststore path (optional)" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="..." onAction="#handleBrowseTimestampTrustStore"/>
                        <PasswordField fx:id="xmlTimestampTrustStorePasswordField" promptText="Password" style="-fx-font-size: 11px;"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button text="Inspect Token" onAction="#handleInspectTimestampToken" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                        <Button text="Validate Token" onAction="#handleValidateTimestampToken" styleClass="action-button" style="-fx-font-size: 10px;"/>
                    </HBox>
                    <Label text="RFC 3161 token report:"/>
                    <TextArea fx:id="xmlTimestampReportArea" prefHeight="220" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                </VBox>
            </TitledPane>
            <TitledPane text="🔍 Verify XML (XAdES)">
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="Paste Signed XML Content:"/>
                    <TextArea fx:id="xmlVerifyInputArea" prefHeight="200" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                    <Label text="TrustStore for trusted validation (optional):"/>
                    <HBox spacing="6">
                        <ComboBox fx:id="xmlVerifyTrustStoreProfileCombo" promptText="Saved KeyStore profile" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Load" onAction="#handleLoadXMLTrustStoreProfile" styleClass="secondary-button" style="-fx-font-size: 10px;"/>
                    </HBox>
                    <HBox spacing="10">
                        <TextField fx:id="xmlVerifyTrustStorePathField" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="..." onAction="#handleBrowseXMLTrustStore"/>
                    </HBox>
                    <PasswordField fx:id="xmlVerifyTrustStorePasswordField" promptText="TrustStore password" style="-fx-font-size: 11px;"/>

                    <Button text="Verify XML" onAction="#handleVerifyXML" styleClass="action-button" maxWidth="180" style="-fx-font-size: 11px;"/>

                    <Label text="Verification Report:"/>
                    <TextArea fx:id="xmlVerifyReportArea" prefHeight="150" editable="false" style="-fx-font-family: 'Monospaced'; -fx-font-size: 10px;"/>
                </VBox>
            </TitledPane>
        </panes>
    </Accordion>
</VBox>
